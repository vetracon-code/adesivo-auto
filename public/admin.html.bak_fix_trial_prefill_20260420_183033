<script id="trial-requests-admin-script">
(function(){
  function fmtDate(v){
    if(!v) return '-';
    try { return new Date(v).toLocaleString('it-IT'); } catch(e){ return v; }
  }

  function esc(v){
    return String(v || '')
      .replace(/&/g,'&amp;')
      .replace(/</g,'&lt;')
      .replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;')
      .replace(/'/g,'&#39;');
  }

  function phoneForWa(v){
    return String(v || '').replace(/[^\d+]/g,'');
  }

  async function loadTrialRequests(){
    const body = document.getElementById('trialRequestsBody');
    const result = document.getElementById('trialRequestsResult');
    if(!body || !result) return;

    result.textContent = 'Caricamento richieste prova gratuita...';
    body.innerHTML = '<tr><td colspan="10" class="trial-muted">Caricamento in corso...</td></tr>';

    try{
      const res = await fetch('/api/admin/trial-requests', { credentials:'same-origin' });
      const out = await res.json();

      if(!res.ok || !out.success){
        result.textContent = out.error || 'Errore caricamento richieste.';
        body.innerHTML = '<tr><td colspan="10" class="trial-muted">Errore caricamento richieste.</td></tr>';
        return;
      }

      const items = out.items || [];
      result.textContent = `Richieste trovate: ${items.length}`;

      if(!items.length){
        body.innerHTML = '<tr><td colspan="10" class="trial-muted">Nessuna richiesta prova gratuita presente.</td></tr>';
        return;
      }

      body.innerHTML = items.map(item => {
        const waText = [
          `Ciao ${item.full_name || ''},`,
          `ho ricevuto la tua richiesta di prova gratuita per il servizio QR veicolo.`,
          `Targa: ${item.plate || '-'}`,
          `Veicolo: ${(item.brand || '') + ' ' + (item.vehicle_model || '')}`.trim(),
          `Ti contatto per procedere con la preparazione della prova gratuita.`
        ].join('\n');

        const waUrl = `https://wa.me/${encodeURIComponent(phoneForWa(item.phone || ''))}?text=${encodeURIComponent(waText)}`;
        return `
          <tr>
            <td>${esc(fmtDate(item.created_at))}</td>
            <td>${esc(item.full_name || '-')}</td>
            <td>${item.phone ? `<a href="tel:${esc(item.phone)}">${esc(item.phone)}</a>` : '-'}</td>
            <td>${item.email ? `<a href="mailto:${esc(item.email)}">${esc(item.email)}</a>` : '-'}</td>
            <td><strong>${esc(item.plate || '-')}</strong></td>
            <td>${esc(((item.brand || '') + ' ' + (item.vehicle_model || '')).trim() || '-')}</td>
            <td>${esc(item.color || '-')}</td>
            <td>${esc(item.notes || '-')}</td>
            <td>${item.marketing_consent ? '<span class="trial-badge yes">SI</span>' : '<span class="trial-badge no">NO</span>'}</td>
            <td>
              <div class="trial-actions">
                ${item.phone ? `<button class="trial-mini" type="button" onclick="window.open('${waUrl}','_blank')">WhatsApp</button>` : ''}
                ${item.phone ? `<button class="trial-mini" type="button" onclick="navigator.clipboard.writeText('${esc(item.phone || '')}')">Copia numero</button>` : ''}
                ${item.plate ? `<button class="trial-mini" type="button" onclick="navigator.clipboard.writeText('${esc(item.plate || '')}')">Copia targa</button>` : ''}
                ${item.email ? `<button class="trial-mini" type="button" onclick="window.location.href='mailto:${esc(item.email || '')}'">Email</button>` : ''}
                <button class="trial-mini" type="button" onclick='openTrialEditModal(${JSON.stringify("__ITEM__")})'>Modifica</button>
                <button class="trial-mini" type="button" onclick="deleteTrialRequest(${item.id})">Elimina</button>
              </div>
            </td>
          </tr>
        `;
      }).join('');
    }catch(err){
      result.textContent = 'Errore di collegamento durante il caricamento.';
      body.innerHTML = '<tr><td colspan="10" class="trial-muted">Errore di collegamento.</td></tr>';
    }
  }

  window.loadTrialRequests = loadTrialRequests;

  document.addEventListener('DOMContentLoaded', function(){
    const btn = document.getElementById('reloadTrialRequestsBtn');
    if (btn) btn.addEventListener('click', loadTrialRequests);
    loadTrialRequests();
  });
})();
</script>


