  <script>
    const bodyEl = document.getElementById('adminTableBody');
    const searchEl = document.getElementById('adminSearch');
    const modal = document.getElementById('editModal');
    const inviteModal = document.getElementById('inviteModal');
    const collectedModal = document.getElementById('collectedModal');
    const abuseModal = document.getElementById('abuseModal');
    const deliverWebAppModal = document.getElementById('deliverWebAppModal');
    const editResult = document.getElementById('editResult');
    const inviteResult = document.getElementById('inviteResult');
    const pushBroadcastResult = document.getElementById('pushBroadcastResult');
    const lastPushList = document.getElementById('lastPushList');
    const lastPushMeta = document.getElementById('lastPushMeta');
    const isSponsoredEl = document.getElementById('isSponsored');
    const sponsorNameEl = document.getElementById('sponsorName');
    let adminItems = [];

    if (isSponsoredEl && sponsorNameEl) {
      isSponsoredEl.addEventListener('change', () => {
        sponsorNameEl.style.display = isSponsoredEl.value === 'yes' ? 'block' : 'none';
        if (isSponsoredEl.value !== 'yes') sponsorNameEl.value = '';
      });
    }
    let deliverWebAppState = null;

    function fmtDate(v){
      if(!v) return '-';
      try { return new Date(v).toLocaleString('it-IT'); } catch { return v; }
    }

    function planLabel(v){
      return v === 'always' ? 'Sempre valido'
        : v === '1week' ? '1 settimana'
        : v === '1month' ? '1 mese'
        : v === '6months' ? '6 mesi'
        : (v || '-');
    }

    function expiryLabel(item){
      if(item.plan_type === 'always') return '<span class="muted">Sempre attivo</span>';
      if(!item.expires_at) return '<span class="muted">-</span>';
      const d = Number(item.days_left);
      if (Number.isNaN(d)) return fmtDate(item.expires_at);
      if (d < 0) return `<span class="danger"><strong>Scaduto da ${Math.abs(d)} gg</strong></span><br><span class="muted">${fmtDate(item.expires_at)}</span>`;
      if (d <= 15) return `<span class="warn"><strong>Scade tra ${d} gg</strong></span><br><span class="muted">${fmtDate(item.expires_at)}</span>`;
      return `<span class="ok"><strong>${d} gg residui</strong></span><br><span class="muted">${fmtDate(item.expires_at)}</span>`;
    }

    function buildRenewLink(item){
      return `${window.location.origin}/renew/u/${encodeURIComponent(item.public_id || '')}`;
    }

    function buildFeedbackLink(item){
      return `${window.location.origin}/feedback/u/${encodeURIComponent(item.public_id || '')}`;
    }

    function buildRenewText(item){
      return `Ciao, ti ricordo che il servizio associato al tuo QR veicolo risulta in scadenza o già scaduto. Per mantenerlo attivo ed evitare interruzioni, puoi proseguire direttamente da qui:\n\n${buildRenewLink(item)}\n\nSe vuoi, posso anche aiutarti io direttamente.`;
    }

    function buildFeedbackText(item){
      return `Ciao, ho visto che il servizio associato al tuo QR veicolo non è stato ancora rinnovato. Se non desideri proseguire, mi sarebbe molto utile capire il motivo tramite un breve form anonimo:\n\n${buildFeedbackLink(item)}\n\nIl tuo riscontro ci aiuta a migliorare il servizio.`;
    }

    async function loadLastBroadcastStatus(){
      try {
        const res = await fetch('/api/admin/last-broadcast-status');
        const data = await res.json();

        const setText = (id, value) => {
          const el = document.getElementById(id);
          if (el) el.textContent = value ?? '-';
        };

        if (!res.ok || !data.success || !data.notification) {
          setText('lastPushSent', 0);
          setText('lastPushOpened', 0);
          setText('lastPushPending', 0);
          if (lastPushMeta) lastPushMeta.textContent = 'Nessuna push inviata.';
          if (lastPushList) lastPushList.innerHTML = '';
          return;
        }

        const n = data.notification;
        const recipients = Array.isArray(data.recipients) ? data.recipients : [];
        const opened = recipients.filter(x => x.status === 'opened').length;
        const pending = recipients.length - opened;

        setText('lastPushSent', n.total_sent ?? recipients.length);
        setText('lastPushOpened', opened);
        setText('lastPushPending', pending);

        if (lastPushMeta) {
          lastPushMeta.textContent = `${n.title || '-'} · ${new Date(n.created_at).toLocaleString('it-IT')}`;
        }

        if (lastPushList) {
          if (!recipients.length) {
            lastPushList.innerHTML = '<div class="muted">Nessun destinatario registrato.</div>';
          } else {
            lastPushList.innerHTML = recipients.slice(0, 20).map(item => `
              <div class="last-push-row">
                <div>
                  <div class="last-push-main">${item.plate || '-'} ${item.code ? '· ' + item.code : ''}</div>
                  <div class="last-push-sub">${item.opened_at ? 'Aperta: ' + new Date(item.opened_at).toLocaleString('it-IT') : 'Non ancora aperta'}</div>
                </div>
                <div class="push-flag ${item.status === 'opened' ? 'opened' : 'pending'}"></div>
              </div>
            `).join('');
          }
        }
      } catch (err) {
        if (lastPushMeta) lastPushMeta.textContent = 'Errore lettura ultima push.';
      }
    }

    async function sendBroadcastPush(){
      const title = document.getElementById('pushTitle').value.trim();
      const message = document.getElementById('pushMessage').value.trim();
      const url = document.getElementById('pushUrl').value.trim();
      const audience = document.getElementById('pushAudience').value;

      pushBroadcastResult.textContent = '';

      if (!title) {
        pushBroadcastResult.textContent = 'Inserisci il titolo della notifica.';
        return;
      }
      if (!message) {
        pushBroadcastResult.textContent = 'Inserisci il messaggio della notifica.';
        return;
      }

      const ok = confirm('Confermi l’invio push massivo ai destinatari selezionati?');
      if (!ok) return;

      pushBroadcastResult.textContent = 'Invio in corso...';

      try {
        const res = await fetch('/api/admin/push-broadcast', {
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ title, message, url, audience })
        });

        const data = await res.json();
        if (!res.ok || !data.success) {
          pushBroadcastResult.textContent = data.error || 'Errore invio push.';
          return;
        }

        pushBroadcastResult.textContent = `Invio completato. Consegnate: ${data.sent || 0} · Fallite: ${data.failed || 0} · Totale target: ${data.total || 0}`;
        loadLastBroadcastStatus();
      } catch (err) {
        pushBroadcastResult.textContent = 'Errore invio push.';
      }
    }

    function statusBadge(v){
      const label = v === 'used' ? 'Attivo'
        : v === 'disabled' ? 'Disattivato'
        : v === 'new' ? 'Nuovo'
        : v === 'reactivated' ? 'Riattivato'
        : (v || '-');
      return `<span class="status ${v || ''}">${label}</span>`;
    }

    function setSummary(summary){
      const setText = (id, value) => {
        const el = document.getElementById(id);
        if (el) el.textContent = value ?? 0;
      };
      setText('kpiActive', summary.active_count ?? 0);
      setText('kpiNew', summary.new_count ?? 0);
      setText('kpiDisabled', summary.disabled_count ?? 0);
      setText('kpiLocalhost', summary.localhost_count ?? 0);
      setText('kpiViews', summary.total_views ?? 0);
      setText('kpiMessages', summary.total_messages ?? 0);
      setText('focusViews', summary.total_views ?? 0);
      setText('focusMessages', summary.total_messages ?? 0);
      setText('focusNew', summary.new_count ?? 0);
      setText('focusLocalhost', summary.localhost_count ?? 0);
    }

    async function loadAdmin(q=''){
      try {
        bodyEl.innerHTML = '<tr><td colspan="11" class="muted">Caricamento in corso...</td></tr>';
        const url = q ? `/api/admin/list-stickers?q=${encodeURIComponent(q)}` : '/api/admin/list-stickers';
        const res = await fetch(url);
        const data = await res.json();

        if(!res.ok || !data.success){
          bodyEl.innerHTML = `<tr><td colspan="11" class="danger">Errore caricamento: ${data.error || 'risposta non valida'}</td></tr>`;
          return;
        }

        adminItems = Array.isArray(data.items) ? data.items : [];
        setSummary(data.summary || {});

        if(!adminItems.length){
          bodyEl.innerHTML = '<tr><td colspan="11" class="muted">Nessun record trovato.</td></tr>';
          return;
        }

        bodyEl.innerHTML = adminItems.map(item => {
          const vehicle = [item.brand, item.vehicle_model].filter(Boolean).join(' ') || '-';
          const qrWarn = item.qr_url && item.qr_url.includes('localhost');
          return `
          <tr>
            <td class="mono">${item.code || '-'}</td>
            <td class="mono">${item.public_id || '-'}</td>
            <td>${item.plate || '-'}</td>
            <td>${vehicle}</td>
            <td>${item.offered_by || '-'}</td>
            <td>${statusBadge(item.status)}</td>
            <td>${item.subscription_label || planLabel(item.plan_type)}</td>
            <td>${expiryLabel(item)}</td>
            <td>${item.feedback_bonus_used ? '<span class="warn"><strong>Usato</strong></span>' : '<span class="ok"><strong>Disponibile</strong></span>'}</td>
            <td>${item.invite_sent_to ? `${item.invite_sent_to}<br><span class="muted">${item.invite_channel || '-'} · ${fmtDate(item.invite_sent_at)}</span>` : '-'}</td>
            <td class="mono ${qrWarn ? 'warn' : ''}">${item.qr_url || '-'}</td>
            <td>
              <div class="actions">
                ${item.status === 'new' ? `<button class="mini" onclick="openInvite('${item.code}')">Invia</button>` : ''}
                ${item.status === 'used' ? `<button class="mini" onclick="openDeliverWebApp('${item.code}')">Consegna Web App</button>` : ''}
                ${item.owner_access_token ? `<button class="mini" onclick="copyOwnerAccessLink('${item.code}')">Accesso diretto</button>` : ''}
                ${item.phone ? `<button class="mini" onclick="sendRenewWhatsApp('${item.code}')">Invia rinnovo</button>` : ''}
                ${item.phone ? `<button class="mini" onclick="sendFeedbackWhatsApp('${item.code}')">Chiedi feedback</button>` : ''}
                <button class="mini" onclick="printSticker('${item.code}')">Stampa</button>
                <button class="mini" onclick="printQrHd('${item.code}')">Solo QR HD</button>
                <button class="mini" onclick="openEdit('${item.code}')">Modifica</button>
                <button class="mini" onclick="fixQrUrl('${item.code}')">Correggi URL</button>
                <button class="mini" onclick="setStatus('${item.code}','disabled')">Disattiva</button>
                <button class="mini" onclick="setStatus('${item.code}','used')">Riattiva</button>
                <button class="mini" onclick="deleteSticker('${item.code}')">Elimina</button>
              </div>
            </td>
          </tr>
        `;
      }).join('');
      } catch (err) {
        console.error(err);
        bodyEl.innerHTML = `<tr><td colspan="11" class="danger">Errore rendering admin: ${err.message || err}</td></tr>`;
      }
    }


    function buildInviteLink(item){
      return `${window.location.origin}/activate.html?code=${encodeURIComponent(item.code || '')}`;
    }

    function buildInviteText(item, channel, variant){
      const link = buildInviteLink(item);
      if(channel === 'whatsapp' && variant === 'short'){
        return `Ti invio un codice già pronto per attivare il tuo adesivo QR veicolo. In pochi minuti puoi renderlo operativo e ricevere segnalazioni rapide in caso di urto, intralcio o necessità reale.\n\nAttivalo da qui: ${link}`;
      }
      if(channel === 'whatsapp' && variant === 'full'){
        return `Ti invio il tuo codice personale per attivare il sistema QR dedicato al veicolo.\n\nCome funziona:\n1. apri il link\n2. inserisci i dati richiesti del veicolo\n3. completa l’attivazione\n4. il codice sarà subito pronto per essere utilizzato\n\nVantaggi principali:\n- permette un contatto rapido in caso di urto, intralcio o urgenza\n- evita di esporre pubblicamente il numero di telefono\n- rende più semplice farsi contattare quando serve davvero\n\nNel servizio è incluso anche il monitoraggio degli accessi, con la possibilità di verificare visualizzazioni, invii avviati e area indicativa di accesso.\n\nLink attivazione: ${link}`;
      }
      if(channel === 'email' && variant === 'short'){
        return `Ti invio il tuo codice già pronto per essere attivato. In pochi minuti puoi rendere operativo il sistema e permettere a chi trova il veicolo di contattarti rapidamente in caso di necessità.\n\nLink attivazione: ${link}`;
      }
      return `Ti invio il codice personale per attivare il sistema QR dedicato al veicolo.\n\nProcedura di attivazione:\n1. apri il link riportato sotto\n2. inserisci i dati richiesti del veicolo\n3. completa l’attivazione\n4. il sistema sarà subito operativo\n\nUna volta attivo, il QR consente a chi trova il veicolo di inviarti rapidamente una segnalazione in caso di urto, intralcio, emergenza o altra necessità reale, senza esporre direttamente il tuo numero in modo pubblico.\n\nIl servizio include anche il monitoraggio delle interazioni, con visualizzazione degli accessi, degli invii avviati e dell’area indicativa di accesso.\n\nLink attivazione: ${link}`;
    }

    function refreshInvitePreview(){
      const code = document.getElementById('inviteCode').value;
      const item = adminItems.find(x => x.code === code);
      if(!item) return;
      const channel = document.getElementById('inviteChannel').value;
      const variant = document.getElementById('inviteVariant').value;
      document.getElementById('inviteLink').value = buildInviteLink(item);
      document.getElementById('invitePreview').value = buildInviteText(item, channel, variant);
    }

    window.openInvite = function(code){
      const item = adminItems.find(x => x.code === code);
      if(!item) return;
      document.getElementById('inviteCode').value = item.code || '';
      document.getElementById('inviteSentTo').value = item.invite_sent_to || '';
      document.getElementById('inviteChannel').value = item.invite_channel || 'whatsapp';
      document.getElementById('inviteTarget').value = item.invite_target || '';
      document.getElementById('inviteVariant').value = item.invite_variant || 'short';
      inviteResult.textContent = '';
      refreshInvitePreview();
      inviteModal.style.display = 'flex';
    }



    window.printSticker = function(code){
      window.open(`/sticker.html?code=${encodeURIComponent(code)}`, '_blank');
    }

    window.deleteSticker = async function(code){
      const ok = confirm(`Confermi l'eliminazione definitiva del codice ${code}?`);
      if(!ok) return;

      const res = await fetch('/api/admin/delete-sticker', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ code })
      });

      const data = await res.json();
      alert(data.success ? 'Codice eliminato.' : (data.error || 'Errore eliminazione.'));
      if(data.success) loadAdmin(searchEl.value.trim());
    }




    window.copyOwnerAccessLink = async function(code){
      const item = adminItems.find(x => x.code === code);
      if(!item || !item.owner_access_token) return;
      const link = `${window.location.origin}/owner-access/${item.owner_access_token}`;
      try {
        await navigator.clipboard.writeText(link);
        alert('Link di accesso diretto copiato.');
      } catch (e) {
        alert(link);
      }
    }



    function buildOwnerWebAppLink(item){
      return `${window.location.origin}/owner-simple.html?code=${encodeURIComponent(item.code || '')}&plate=${encodeURIComponent(item.plate || '')}`;
    }

    window.openDeliverWebApp = function(code){
      const item = adminItems.find(x => x.code === code);
      if (!item) return;

      if (!item.plate) {
        alert('Questo record non ha ancora una targa associata. La Web App proprietario richiede codice e targa.');
        return;
      }

      deliverWebAppState = item;
      const vehicle = [item.brand, item.vehicle_model].filter(Boolean).join(' ') || 'Veicolo registrato';
      const link = buildOwnerWebAppLink(item);

      document.getElementById('deliverWebAppCode').textContent = item.code || '-';
      document.getElementById('deliverWebAppVehicle').textContent = `${vehicle} — ${item.plate || '-'}`;
      document.getElementById('deliverWebAppLink').textContent = link;
      document.getElementById('deliverWebAppResult').textContent = '';
      deliverWebAppModal.style.display = 'flex';
    }



    window.deliverCloseModal = function(){
      if (deliverWebAppModal) deliverWebAppModal.style.display = 'none';
    };

    window.deliverOpenWebApp = function(){
      if (!deliverWebAppState) return;
      window.open(buildOwnerWebAppLink(deliverWebAppState), '_blank');
    };

    window.deliverCopyWebAppLink = async function(){
      if (!deliverWebAppState) return;
      const link = buildOwnerWebAppLink(deliverWebAppState);
      const resultEl = document.getElementById('deliverWebAppResult');
      try {
        await navigator.clipboard.writeText(link);
        resultEl.textContent = 'Link Web App copiato.';
      } catch (e) {
        resultEl.textContent = link;
      }
    };

    window.deliverSendWebAppWhatsApp = function(){};

    window.deliverSendWebAppEmail = function(){
      if (!deliverWebAppState) return;
      const link = buildOwnerWebAppLink(deliverWebAppState);
      const vehicle = [deliverWebAppState.brand, deliverWebAppState.vehicle_model].filter(Boolean).join(' ') || 'veicolo';
      const subject = 'La tua Web App personale è pronta';
      const body = `La tua Web App personale è pronta.\n\nDa qui puoi controllare se il tuo QR è attivo, vedere aperture, messaggi ricevuti e scadenza del servizio.\n\n${vehicle} — ${deliverWebAppState.plate || ''}\n${link}`;
      window.location.href = `mailto:?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
    };

    window.deliverSendInstallGuide = function(){
      if (!deliverWebAppState) return;
      const link = buildOwnerWebAppLink(deliverWebAppState);
      const vehicle = [deliverWebAppState.brand, deliverWebAppState.vehicle_model].filter(Boolean).join(' ') || 'veicolo';
      const plate = deliverWebAppState.plate || '';
      const text = `La tua Web App personale è pronta.\n\n${vehicle} — ${plate}\n${link}\n\nPer salvarla sul telefono:\n\nIPHONE / IPAD\n1. Apri il link in Safari\n2. Tocca Condividi\n3. Scegli Aggiungi a Home\n4. Riaprila dalla Home\n5. Poi attiva le notifiche dall'interno della Web App\n\nANDROID\n1. Apri il link nel browser\n2. Usa Salva sul dispositivo / Installa app quando disponibile\n3. Poi attiva le notifiche dall'interno della Web App\n\nSe hai dubbi, contattami e ti guiderò io.`;
      window.open(`https://wa.me/?text=${encodeURIComponent(text)}`, '_blank');
    };


    window.sendRenewWhatsApp = function(){}

    window.sendFeedbackWhatsApp = function(){}


    window.openEdit = function(code){
      const item = adminItems.find(x => x.code === code);
      if(!item) return;
      document.getElementById('editCode').value = item.code || '';
      document.getElementById('editPublicId').value = item.public_id || '';
      document.getElementById('editBrand').value = item.brand || '';
      document.getElementById('editModel').value = item.vehicle_model || '';
      document.getElementById('editPlate').value = item.plate || '';
