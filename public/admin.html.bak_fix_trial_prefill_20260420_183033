    document.getElementById('trialEditBrand').value = item.brand || '';
    document.getElementById('trialEditModel').value = item.vehicle_model || '';
    document.getElementById('trialEditColor').value = item.color || '';
    document.getElementById('trialEditNotes').value = item.notes || '';
    document.getElementById('trialEditMarketing').value = item.marketing_consent ? 'true' : 'false';
    document.getElementById('trialEditResult').textContent = '';
    document.getElementById('trialEditModal').style.display = 'flex';
  };

  window.closeTrialEditModal = function(){
    document.getElementById('trialEditModal').style.display = 'none';
  };

  window.deleteTrialRequest = async function(id){
    if (!id) return;
    if (!confirm('Confermi l’eliminazione della richiesta prova gratuita?')) return;

    try{
      const res = await fetch('/api/admin/delete-trial-request', {
        method:'POST',
        headers:{'Content-Type':'application/json'},
        credentials:'same-origin',
        body: JSON.stringify({ id })
      });
      const out = await res.json();
      if (!res.ok || !out.success) {
        alert(out.error || 'Errore eliminazione richiesta.');
        return;
      }
      if (window.loadTrialRequests) await window.loadTrialRequests();
    }catch(err){
      alert('Errore di collegamento durante l’eliminazione.');
    }
  };

  document.addEventListener('DOMContentLoaded', function(){
    const form = document.getElementById('trialEditForm');
    if (!form) return;

    form.addEventListener('submit', async function(e){
      e.preventDefault();

      const btn = document.getElementById('saveTrialEditBtn');
      const result = document.getElementById('trialEditResult');
      btn.disabled = true;
      btn.textContent = 'Salvataggio...';
      result.textContent = '';

      const payload = {
        id: document.getElementById('trialEditId').value,
        full_name: document.getElementById('trialEditFullName').value.trim(),
        phone: document.getElementById('trialEditPhone').value.trim(),
        email: document.getElementById('trialEditEmail').value.trim(),
        plate: document.getElementById('trialEditPlate').value.trim().toUpperCase(),
        brand: document.getElementById('trialEditBrand').value.trim(),
        vehicle_model: document.getElementById('trialEditModel').value.trim(),
        color: document.getElementById('trialEditColor').value.trim(),
        notes: document.getElementById('trialEditNotes').value.trim(),
        privacy_consent: true,
        marketing_consent: document.getElementById('trialEditMarketing').value === 'true'
      };

      try{
        const res = await fetch('/api/admin/update-trial-request', {
          method:'POST',
          headers:{'Content-Type':'application/json'},
          credentials:'same-origin',
          body: JSON.stringify(payload)
        });
        const out = await res.json();

        if (!res.ok || !out.success) {
          result.textContent = out.error || 'Errore salvataggio modifica.';
        } else {
          result.textContent = 'Modifica salvata correttamente.';
          if (window.loadTrialRequests) await window.loadTrialRequests();
          setTimeout(() => {
            window.closeTrialEditModal();
          }, 500);
        }
      }catch(err){
        result.textContent = 'Errore di collegamento durante il salvataggio.';
      }finally{
        btn.disabled = false;
        btn.textContent = 'Salva modifiche';
      }
    });
  });
})();
</script>

</body>
</html>
