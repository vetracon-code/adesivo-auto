<!doctype html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Dashboard Admin</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    :root{
      --accent:#2c74ff;
      --accent2:#5aa0ff;
      --bg1:#050b14;
      --bg2:#0a1320;
      --panel:#0b1523;
      --line:rgba(255,255,255,.10);
      --text:#f7fbff;
      --muted:#b6c2d4;
      --soft:rgba(255,255,255,.04);
      --warn:#ffd27d;
      --danger:#ffb0b0;
      --ok:#9de2a7;
    }
    *{box-sizing:border-box}
    html,body{
      margin:0;padding:0;min-height:100%;
      font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","Segoe UI",Arial,sans-serif;
      background:
        radial-gradient(circle at 18% 0%, rgba(33,78,166,.22), transparent 28%),
        linear-gradient(180deg,var(--bg1) 0%,#07101b 48%,var(--bg2) 100%);
      color:var(--text)
    }
    .wrap{width:min(1450px,calc(100% - 24px));margin:0 auto;padding:28px 0 34px}
    .panel{
      border-radius:30px;overflow:hidden;
      background:
        radial-gradient(circle at 70% 8%, rgba(45,110,240,.12), transparent 24%),
        linear-gradient(180deg, rgba(11,21,35,.99) 0%, rgba(8,16,27,.995) 100%);
      border:1px solid rgba(255,255,255,.08);
      box-shadow:0 24px 56px rgba(0,0,0,.38)
    }
    .head{padding:28px 26px 20px}
    .title{
      margin:0;line-height:.94;letter-spacing:-.06em;font-weight:900;
      font-size:clamp(2.2rem,5.2vw,3.8rem);text-transform:uppercase
    }
    .title span{display:block;margin-top:6px;color:var(--accent2)}
    .sub{margin:14px 0 0;color:var(--muted);max-width:850px;line-height:1.55}
    .focus-wrap{
      padding:0 26px 18px;
    }
    .focus-card{
      display:grid;
      grid-template-columns:1.4fr .9fr;
      gap:14px;
      border-radius:24px;
      border:1px solid rgba(255,255,255,.08);
      background:linear-gradient(180deg, rgba(255,255,255,.04) 0%, rgba(255,255,255,.02) 100%);
      padding:18px 18px;
    }
    .focus-title{
      margin:0;
      font-size:1.08rem;
      font-weight:900;
      letter-spacing:-.02em;
      color:#fff;
    }
    .focus-copy{
      margin-top:8px;
      color:var(--muted);
      line-height:1.52;
      max-width:620px;
      font-size:.95rem;
    }
    .focus-stats{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:10px;
      align-content:start;
    }
    .focus-mini{
      border-radius:18px;
      border:1px solid rgba(255,255,255,.08);
      background:rgba(255,255,255,.03);
      padding:14px 14px;
    }
    .focus-mini .label{
      color:#9fb1c8;
      font-size:.8rem;
      text-transform:uppercase;
      letter-spacing:.04em;
    }
    .focus-mini .value{
      margin-top:6px;
      font-size:1.25rem;
      font-weight:900;
      color:#fff;
    }
    .kpis{
      padding:0 26px 20px;
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:12px
    }
    .kpi{
      border-radius:20px;
      background:linear-gradient(180deg, rgba(255,255,255,.03) 0%, rgba(255,255,255,.015) 100%);
      border:1px solid var(--line);
      padding:16px
    }
    .kpi .label{color:#9fb1c8;font-size:.82rem;text-transform:uppercase;letter-spacing:.04em}
    .kpi .value{margin-top:8px;font-size:1.45rem;font-weight:900;color:#fff}
    .toolbar{
      padding:0 26px 20px;
      display:flex;gap:12px;flex-wrap:wrap;align-items:center
    }
    .search,.select,.input{
      min-height:48px;border-radius:14px;border:1px solid var(--line);
      background:var(--soft);color:#fff;padding:0 14px
    }
    .search{min-width:340px}
    .btn{
      min-height:48px;padding:0 16px;border-radius:14px;border:0;cursor:pointer;
      color:#fff;font-weight:800
    }
    .btn-primary{background:linear-gradient(135deg,var(--accent) 0%,var(--accent2) 100%)}
    .btn-secondary{background:rgba(255,255,255,.06);border:1px solid var(--line)}
    .btn-warn{background:rgba(255,210,125,.10);border:1px solid rgba(255,210,125,.25);color:#ffe3a9}
    .table-wrap{padding:0 26px 26px;overflow:auto}
    table{
      width:100%;border-collapse:collapse;background:rgba(255,255,255,.02);
      border:1px solid var(--line);border-radius:18px;overflow:hidden
    }
    th,td{
      padding:12px 10px;text-align:left;border-bottom:1px solid rgba(255,255,255,.06);
      vertical-align:top;font-size:.92rem
    }
    th{color:#dce7f7;background:rgba(255,255,255,.04);position:sticky;top:0}
    td{color:#d1dbea}
    .mono{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:.84rem}
    .status{
      display:inline-flex;align-items:center;justify-content:center;
      min-height:28px;padding:0 10px;border-radius:999px;font-size:.78rem;font-weight:800
    }
    .status.used{background:rgba(157,226,167,.12);color:var(--ok);border:1px solid rgba(157,226,167,.20)}
    .status.new{background:rgba(90,160,255,.12);color:#b6d4ff;border:1px solid rgba(90,160,255,.20)}
    .status.disabled{background:rgba(255,176,176,.12);color:var(--danger);border:1px solid rgba(255,176,176,.20)}
    .status.reactivated{background:rgba(255,210,125,.10);color:#ffe3a9;border:1px solid rgba(255,210,125,.20)}
    .actions{display:flex;gap:8px;flex-wrap:wrap}
    .mini{
      min-height:34px;padding:0 10px;border-radius:10px;border:1px solid var(--line);
      background:rgba(255,255,255,.05);color:#fff;cursor:pointer;font-size:.82rem
    }
    .warn{color:var(--warn)}
    .danger{color:var(--danger)}
    .muted{color:var(--muted)}
    .modal{
      position:fixed;inset:0;background:rgba(0,0,0,.55);display:none;
      align-items:center;justify-content:center;padding:20px
    }
    .modal-card{
      width:min(760px,100%);background:#0d1727;border:1px solid var(--line);
      border-radius:22px;padding:20px
    }
    .grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .full{grid-column:1 / -1}
    .helper{padding:0 26px 20px;color:var(--muted);font-size:.9rem}
    .push-broadcast{
      margin:0 26px 20px;
      padding:18px;
      border-radius:24px;
      border:1px solid rgba(255,255,255,.08);
      background:linear-gradient(180deg, rgba(255,255,255,.04) 0%, rgba(255,255,255,.02) 100%);
    }
    .push-broadcast h2{
      margin:0;
      font-size:1.05rem;
      font-weight:900;
      letter-spacing:-.02em;
      color:#fff;
    }
    .push-broadcast .copy{
      margin-top:8px;
      color:var(--muted);
      line-height:1.5;
      font-size:.94rem;
      max-width:860px;
    }
    .push-grid{
      margin-top:14px;
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:12px;
    }
    .push-grid .full{
      grid-column:1 / -1;
    }
    .push-broadcast textarea{
      min-height:110px;
      padding:12px 14px;
      resize:vertical;
    }
    .push-result{
      margin-top:12px;
      color:var(--muted);
      font-size:.9rem;
      line-height:1.45;
    }
    .last-push{
      margin:0 26px 20px;
      padding:18px;
      border-radius:24px;
      border:1px solid rgba(255,255,255,.08);
      background:linear-gradient(180deg, rgba(255,255,255,.04) 0%, rgba(255,255,255,.02) 100%);
    }
    .last-push h2{
      margin:0;
      font-size:1.02rem;
      font-weight:900;
      letter-spacing:-.02em;
      color:#fff;
    }
    .last-push-copy{
      margin-top:8px;
      color:var(--muted);
      line-height:1.5;
      font-size:.94rem;
    }
    .last-push-stats{
      margin-top:14px;
      display:grid;
      grid-template-columns:repeat(3,1fr);
      gap:12px;
    }
    .last-push-box{
      border-radius:18px;
      border:1px solid rgba(255,255,255,.08);
      background:rgba(255,255,255,.03);
      padding:14px 14px;
    }
    .last-push-box .label{
      color:#9fb1c8;
      font-size:.8rem;
      text-transform:uppercase;
      letter-spacing:.04em;
    }
    .last-push-box .value{
      margin-top:6px;
      font-size:1.2rem;
      font-weight:900;
      color:#fff;
    }
    .last-push-list{
      margin-top:14px;
      display:grid;
      gap:10px;
    }
    .last-push-row{
      display:flex;
      justify-content:space-between;
      gap:12px;
      align-items:center;
      padding:12px 14px;
      border-radius:16px;
      border:1px solid rgba(255,255,255,.08);
      background:rgba(255,255,255,.03);
    }
    .last-push-main{
      color:#fff;
      font-weight:800;
      line-height:1.3;
    }
    .last-push-sub{
      margin-top:4px;
      color:var(--muted);
      font-size:.86rem;
      line-height:1.4;
    }
    .push-flag{
      min-width:18px;
      width:18px;
      height:18px;
      border-radius:999px;
      flex:0 0 auto;
    }
    .push-flag.opened{
      background:#20c05c;
      box-shadow:0 0 0 4px rgba(32,192,92,.15);
    }
    .push-flag.pending{
      background:#d64545;
      box-shadow:0 0 0 4px rgba(214,69,69,.15);
    }
    @media (max-width:1200px){.kpis{grid-template-columns:repeat(2,1fr)}}
    @media (max-width:900px){
      .grid{grid-template-columns:1fr}
      .search{min-width:unset;width:100%}
      .kpis{grid-template-columns:repeat(2,1fr)}
      .focus-card{grid-template-columns:1fr}
      .focus-stats{grid-template-columns:1fr 1fr}
    }
    @media (max-width:640px){.kpis{grid-template-columns:1fr}}
  
.trial-card{
  margin-top:14px;
  border-radius:22px;
  background:linear-gradient(180deg, rgba(255,255,255,.88) 0%, rgba(248,251,255,.96) 100%);
  border:1px solid rgba(34,48,70,.08);
  box-shadow:0 10px 28px rgba(30,46,82,.06);
  padding:16px;
}
.trial-head{
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
  margin-bottom:10px;
}
.trial-title{
  font-size:.95rem;
  font-weight:900;
  text-transform:uppercase;
  letter-spacing:.05em;
}
.trial-muted{
  color:#6b778c;
  font-size:.86rem;
}
.trial-table-wrap{
  overflow:auto;
  border-radius:16px;
  border:1px solid rgba(34,48,70,.08);
  background:rgba(255,255,255,.72);
}
.trial-table{
  width:100%;
  border-collapse:collapse;
  min-width:980px;
}
.trial-table th,
.trial-table td{
  padding:10px 11px;
  text-align:left;
  font-size:.85rem;
  border-bottom:1px solid rgba(34,48,70,.08);
  vertical-align:top;
}
.trial-table th{
  font-size:.78rem;
  text-transform:uppercase;
  letter-spacing:.05em;
  color:#6b778c;
  background:rgba(255,255,255,.82);
}
.trial-actions{
  display:flex;
  gap:6px;
  flex-wrap:wrap;
}
.trial-mini{
  min-height:32px;
  padding:0 10px;
  border-radius:10px;
  border:1px solid rgba(34,48,70,.10);
  background:rgba(255,255,255,.88);
  cursor:pointer;
  font-size:.8rem;
  font-weight:700;
}
.trial-badge{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  min-height:26px;
  padding:0 9px;
  border-radius:999px;
  font-size:.74rem;
  font-weight:800;
  border:1px solid rgba(34,48,70,.08);
}
.trial-badge.yes{
  background:rgba(141,255,177,.10);
  color:#2f8b56;
}
.trial-badge.no{
  background:rgba(255,143,143,.10);
  color:#c25b5b;
}


.trial-modal{
  position:fixed;
  inset:0;
  display:none;
  align-items:center;
  justify-content:center;
  background:rgba(0,0,0,.45);
  z-index:3000;
  padding:18px;
}
.trial-modal-card{
  width:min(760px,100%);
  max-height:90vh;
  overflow:auto;
  border-radius:22px;
  background:linear-gradient(180deg, rgba(255,255,255,.96) 0%, rgba(248,251,255,.98) 100%);
  border:1px solid rgba(34,48,70,.10);
  box-shadow:0 18px 42px rgba(30,46,82,.16);
  padding:18px;
}
.trial-form-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:10px;
}
.trial-field{
  display:grid;
  gap:6px;
}
.trial-field label{
  font-size:.8rem;
  font-weight:800;
  color:#31445d;
}
.trial-field input,
.trial-field textarea{
  width:100%;
  min-height:40px;
  padding:10px 12px;
  border-radius:12px;
  border:1px solid rgba(34,48,70,.12);
  background:#fff;
}
.trial-field textarea{
  min-height:90px;
  resize:vertical;
}
.trial-modal-actions{
  display:flex;
  gap:8px;
  flex-wrap:wrap;
  margin-top:14px;
}
@media (max-width:760px){
  .trial-form-grid{grid-template-columns:1fr}
}

</style>
</head>
<body>
  <div class="wrap">

<div class="trial-card">
  <div class="trial-head">
    <div>
      <div class="trial-title">Richieste prova gratuita</div>
      <div class="trial-muted">Lead raccolti dalla nuova landing pubblica con prova gratuita 30 giorni.</div>
    </div>
    <button id="reloadTrialRequestsBtn" class="btn btn-secondary" type="button">Aggiorna richieste</button>
  </div>

  <div id="trialRequestsResult" class="trial-muted" style="margin-bottom:10px;">Caricamento in corso...</div>

  <div class="trial-table-wrap">
    <table class="trial-table">
      <thead>
        <tr>
          <th>Data</th>
          <th>Nome</th>
          <th>Cellulare</th>
          <th>Email</th>
          <th>Targa</th>
          <th>Veicolo</th>
          <th>Colore</th>
          <th>Note</th>
          <th>Marketing</th>
          <th>Azioni</th>
        </tr>
      </thead>
      <tbody id="trialRequestsBody">
        <tr><td colspan="10" class="trial-muted">Caricamento in corso...</td></tr>
      </tbody>
    </table>
  </div>
</div>

    <div class="panel">
      <div class="head">
        <h1 class="title">DASHBOARD<span>SERVIZIO</span></h1>
        <p class="sub">Il tuo QR è attivo. Monitora aperture, ritorni e segnalazioni. Da qui puoi gestire record, link, stato del servizio e dati raccolti.</p>
      </div>

      <div class="focus-wrap">
        <div class="focus-card">
          <div>
            <h2 class="focus-title">Messaggi arrivati</h2>
            <div class="focus-copy">Qui controlli subito se i QR stanno ricevendo segnalazioni reali. Apri il pannello raccolta per leggere i messaggi e verificare i dati più utili.</div>
            <div class="actions" style="margin-top:14px;">
              <button id="adminCollectedBtnTop" class="btn btn-warn" type="button">MESSAGGI E DATI RACCOLTI</button>
            </div>
          </div>
          <div class="focus-stats">
            <div class="focus-mini">
              <div class="label">Segnalazioni inviate</div>
              <div class="value" id="focusMessages">-</div>
            </div>
            <div class="focus-mini">
              <div class="label">Aperture pagina QR</div>
              <div class="value" id="focusViews">-</div>
            </div>
            <div class="focus-mini">
              <div class="label">Nuovi da attivare</div>
              <div class="value" id="focusNew">-</div>
            </div>
            <div class="focus-mini">
              <div class="label">Link da correggere</div>
              <div class="value" id="focusLocalhost">-</div>
            </div>
          </div>
        </div>
      </div>

      <div class="kpis">
        <div class="kpi"><div class="label">Aperture pagina QR</div><div class="value" id="kpiViews">-</div></div>
        <div class="kpi"><div class="label">Segnalazioni inviate</div><div class="value" id="kpiMessages">-</div></div>
        <div class="kpi"><div class="label">Nuovi da attivare</div><div class="value" id="kpiNew">-</div></div>
        <div class="kpi"><div class="label">Link da correggere</div><div class="value" id="kpiLocalhost">-</div></div>
      </div>

      <div class="toolbar">
        <input id="adminSearch" class="search" type="text" placeholder="Cerca per codice, public_id o targa">
        <button id="adminSearchBtn" class="btn btn-primary" type="button">Cerca</button>
        <button id="adminReloadBtn" class="btn btn-secondary" type="button">Ricarica</button>
        <button id="adminAbuseBtnTop" class="btn btn-secondary" type="button">Blocchi abuso</button>
        <button id="adminLogoutBtn" class="btn btn-secondary" type="button">Logout</button>
      </div>

      <div class="toolbar" style="padding-top:0;">
        <select id="adminPlanType" class="select">
          <option value="always">Sempre valido</option>
          <option value="1week">Valido 1 settimana</option>
          <option value="1month">Valido 1 mese</option>
          <option value="6months">Valido 6 mesi</option>
        </select>
        <select id="isSponsored" class="select">
          <option value="no" selected>Non sponsorizzato</option>
          <option value="yes">Sponsorizzato</option>
        </select>
        <input id="sponsorName" class="input" placeholder="Servizio offerto da" style="display:none;min-width:260px;">
        <button id="adminCreateCodeBtn" class="btn btn-primary" type="button">Genera nuovo codice</button>
      </div>

      <div id="adminCreateResult" class="helper"></div>

      <div class="push-broadcast">
        <h2>Invio push clienti</h2>
        <div class="copy">Invia una notifica push simultanea ai clienti con notifiche attive. Se inserisci un URL, l’utente lo aprirà toccando la notifica.</div>
        <div class="push-grid">
          <input id="pushTitle" class="input" placeholder="Titolo notifica">
          <select id="pushAudience" class="select">
            <option value="all">Tutti con push attivo</option>
            <option value="used">Solo attivi</option>
            <option value="new">Solo nuovi da attivare</option>
            <option value="disabled">Solo disattivati</option>
            <option value="reactivated">Solo riattivati</option>
          </select>
          <textarea id="pushMessage" class="input full" placeholder="Messaggio push"></textarea>
          <input id="pushUrl" class="input full" placeholder="URL da aprire al tap sulla notifica (facoltativo)">
        </div>
        <div class="actions" style="margin-top:14px;">
          <button id="sendBroadcastPushBtn" class="btn btn-primary" type="button">Invia push ora</button>
        </div>
        <div id="pushBroadcastResult" class="push-result"></div>
      </div>

      <div class="last-push">
        <h2>Ultima push inviata</h2>
        <div class="last-push-copy">Verde = notifica aperta. Rosso = non ancora aperta.</div>
        <div class="last-push-stats">
          <div class="last-push-box"><div class="label">Inviati</div><div class="value" id="lastPushSent">-</div></div>
          <div class="last-push-box"><div class="label">Aperti</div><div class="value" id="lastPushOpened">-</div></div>
          <div class="last-push-box"><div class="label">Non aperti</div><div class="value" id="lastPushPending">-</div></div>
        </div>
        <div id="lastPushMeta" class="last-push-copy" style="margin-top:12px;"></div>
        <div id="lastPushList" class="last-push-list"></div>
      </div>

      <div class="helper">Controlla qui le aperture reali, le segnalazioni inviate e i record che richiedono correzione prima dell’uso pubblico.</div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Codice</th>
              <th>Public ID</th>
              <th>Targa</th>
              <th>Veicolo</th>
              <th>Offerto da</th>
                <th>Stato</th>
              <th>Piano</th>
              <th>Scadenza</th>
              <th>Bonus</th>
              <th>Consegna</th>
              <th>QR URL</th>
              <th>Azioni</th>
            </tr>
          </thead>
          <tbody id="adminTableBody">
            <tr><td colspan="11" class="muted">Caricamento in corso...</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>



  <div id="deliverWebAppModal" class="modal">
    <div class="modal-card" style="width:min(760px,100%);">
      <h2 style="margin-top:0;">Consegna Web App proprietario</h2>
      <div class="muted" style="margin-bottom:12px;line-height:1.5;">
        Questo link apre direttamente la Web App del proprietario riferita al codice selezionato.
      </div>
      <div style="display:grid;gap:12px;">
        <div>
          <div class="muted" style="margin-bottom:6px;">Codice</div>
          <div id="deliverWebAppCode" class="mono">-</div>
        </div>
        <div>
          <div class="muted" style="margin-bottom:6px;">Veicolo / Targa</div>
          <div id="deliverWebAppVehicle">-</div>
        </div>
        <div>
          <div class="muted" style="margin-bottom:6px;">Link Web App</div>
          <div id="deliverWebAppLink" class="mono" style="word-break:break-all;">-</div>
        </div>
      </div>

      <div class="actions" style="margin-top:16px;display:flex;gap:10px;flex-wrap:wrap;">
        <button id="deliverOpenBtn" class="btn btn-primary" type="button" onclick="deliverOpenWebApp()">Apri Web App</button>
        <button id="deliverCopyBtn" class="btn btn-secondary" type="button" onclick="deliverCopyWebAppLink()">Copia link</button>
                <button id="deliverEmailBtn" class="btn btn-secondary" type="button" onclick="deliverSendWebAppEmail()">Invia via email</button>
