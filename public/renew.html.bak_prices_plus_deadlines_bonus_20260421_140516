<!doctype html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Continua il servizio</title>
  <link rel="stylesheet" href="/style.css">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <style>
    :root{
      --accent:#2c74ff;
      --accent2:#5aa0ff;
      --bg1:#050b14;
      --bg2:#0a1320;
      --line:rgba(255,255,255,.10);
      --text:#f7fbff;
      --muted:#b6c2d4;
      --ok:#8dffb1;
      --warn:#ffd36c;
      --danger:#ff8f8f;
    }
    *{box-sizing:border-box}
    html,body{
      margin:0;padding:0;min-height:100%;
      font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","Segoe UI",Arial,sans-serif;
      background:
        radial-gradient(circle at 18% 0%, rgba(33,78,166,.22), transparent 28%),
        linear-gradient(180deg, var(--bg1) 0%, #07101b 48%, var(--bg2) 100%);
      color:var(--text)
    }
    .wrap{width:min(1080px, calc(100% - 24px));margin:0 auto;padding:32px 0 40px}
    .panel{
      border-radius:30px;overflow:hidden;
      background:
        radial-gradient(circle at 70% 8%, rgba(45,110,240,.12), transparent 24%),
        linear-gradient(180deg, rgba(11,21,35,.99) 0%, rgba(8,16,27,.995) 100%);
      border:1px solid rgba(255,255,255,.08);
      box-shadow:0 24px 56px rgba(0,0,0,.38);
      padding:30px 26px 28px;
    }
    .badge{
      display:inline-block;padding:8px 12px;border-radius:999px;
      background:rgba(255,255,255,.05);border:1px solid var(--line);
      color:#dce7f7;font-size:.88rem;margin-bottom:16px;
    }
    .badge.ok{color:var(--ok)}
    .badge.warn{color:var(--warn)}
    .badge.danger{color:var(--danger)}
    h1{
      margin:0;line-height:.95;letter-spacing:-.06em;font-weight:900;
      font-size:clamp(2.2rem, 5.2vw, 3.8rem);text-transform:uppercase;color:#fff;
    }
    h1 span{display:block;margin-top:6px;color:var(--accent2);text-shadow:0 0 18px rgba(90,160,255,.25)}
    .line{
      width:62px;height:5px;border-radius:999px;
      background:linear-gradient(90deg,var(--accent),var(--accent2));
      margin:18px 0 14px;box-shadow:0 0 18px rgba(90,160,255,.30);
    }
    .sub{margin:0;color:var(--muted);font-size:1rem;line-height:1.6;max-width:820px}
    .vehicle-box{
      margin-top:20px;display:flex;gap:12px;flex-wrap:wrap;align-items:center;
      padding:14px 16px;border-radius:20px;background:rgba(255,255,255,.04);border:1px solid var(--line)
    }
    .vehicle-chip{
      display:inline-flex;align-items:center;justify-content:center;min-height:44px;padding:0 14px;
      border-radius:14px;background:rgba(255,255,255,.05);border:1px solid var(--line);font-weight:900
    }
    .grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:26px}
    .card{
      border-radius:22px;background:linear-gradient(180deg, rgba(255,255,255,.03) 0%, rgba(255,255,255,.015) 100%);
      border:1px solid var(--line);padding:20px;cursor:pointer;transition:.18s ease;
      position:relative;
    }
    .card:hover{transform:translateY(-2px);border-color:rgba(90,160,255,.28)}
    .card.selected{
      border-color:rgba(90,160,255,.7);
      box-shadow:0 0 0 1px rgba(90,160,255,.25) inset, 0 18px 30px rgba(19,72,177,.18);
      background:linear-gradient(180deg, rgba(60,117,255,.10) 0%, rgba(255,255,255,.02) 100%);
    }
    .card.recommended:not(.selected){
      border-color:rgba(90,160,255,.4);
    }
    .card h2{margin:0 0 8px;color:#fff;font-size:1.02rem;font-weight:900;text-transform:uppercase}
    .card .price{font-size:1.12rem;font-weight:900;color:#fff;margin:0 0 10px}
    .card p{margin:0;color:#c2cfdf;line-height:1.55;font-size:.93rem}
    .pill{
      display:inline-block;margin-bottom:10px;padding:6px 10px;border-radius:999px;
      background:rgba(90,160,255,.12);border:1px solid rgba(90,160,255,.18);color:#dce7f7;font-size:.78rem;font-weight:800
    }
    .actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:24px}
    .btn{
      display:inline-flex;align-items:center;justify-content:center;min-height:54px;padding:0 20px;
      border-radius:16px;text-decoration:none;color:#fff;font-weight:900;font-size:.98rem;border:0;cursor:pointer;
    }
    .btn-primary{background:linear-gradient(135deg,var(--accent) 0%,var(--accent2) 100%);box-shadow:0 16px 30px rgba(18,85,204,.32)}
    .btn-secondary{background:rgba(255,255,255,.05);border:1px solid var(--line)}
    .note{
      margin-top:22px;border-radius:18px;padding:15px 18px;background:rgba(255,255,255,.022);
      border:1px solid var(--line);color:#c1ccdb;line-height:1.56;font-size:.94rem;
    }
    .note strong{color:#fff}
    @media (max-width:980px){ .grid{grid-template-columns:repeat(2,1fr)} }
    @media (max-width:760px){
      .grid{grid-template-columns:1fr}
      .wrap{width:min(1080px, calc(100% - 16px))}
      .panel{padding:22px 16px 20px}
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="panel">
      <div id="renewBadge" class="badge">Caricamento...</div>
      <h1>CONTINUA<span>IL TUO SERVIZIO</span></h1>
      <div class="line"></div>
      <p id="renewSub" class="sub">Caricamento dati servizio...</p>

      <div class="vehicle-box">
        <div id="vehiclePlate" class="vehicle-chip">-</div>
        <div id="vehicleModel" class="vehicle-chip">-</div>
      </div>

      <div class="grid">
        <div class="card" data-plan="1month">
          <h2>1 mese</h2>
          <div class="price">Riattivazione breve</div>
          <p>Ideale per riattivare rapidamente il servizio e mantenerlo operativo per un periodo iniziale.</p>
        </div>

        <div class="card recommended selected" data-plan="6months">
          <div class="pill">Consigliato</div>
          <h2>6 mesi</h2>
          <div class="price">Equilibrio migliore</div>
          <p>La soluzione più equilibrata per continuare il servizio più a lungo senza pensieri.</p>
        </div>

        <div class="card" data-plan="1year">
          <h2>1 anno</h2>
          <div class="price">Miglior continuità</div>
          <p>La scelta più naturale per chi vuole stabilità, comodità e meno rinnovi durante l’anno.</p>
        </div>

        <div class="card" data-plan="always">
          <h2>Sempre attivo</h2>
          <div class="price">Versione definitiva</div>
          <p>Pensata per chi desidera lasciare il servizio sempre attivo senza rinnovi periodici.</p>
        </div>
      </div>

      <div class="actions">
        <button id="mainActionBtn" class="btn btn-primary" type="button">Prosegui con 6 mesi</button>
        <a id="feedbackLinkBtn" href="#" class="btn btn-secondary">Lascia un feedback</a>
      </div>

      <div class="note">
        <strong>Nota:</strong> il piano selezionato verrà collegato nel prossimo passaggio al metodo di pagamento, così il rinnovo potrà essere completato direttamente online.
      </div>
    </div>
  </div>

  <script>
    const pathMatch = window.location.pathname.match(/\/renew\/u\/([A-Z0-9]+)/i);
    const publicId = pathMatch ? pathMatch[1].trim().toUpperCase() : '';
    let selectedPlan = '6months';

    function feedbackUrl() {
      return `/feedback/u/${encodeURIComponent(publicId)}`;
    }

    function fmtDateOnly(v){
      if (!v) return '-';
      try { return new Date(v).toLocaleDateString('it-IT'); } catch { return v; }
    }

    function setBadge(el, text, cls){
      el.textContent = text;
      el.className = `badge ${cls || ''}`.trim();
    }

    function planButtonLabel(plan){
      if (plan === '1month') return 'Prosegui con 1 mese';
      if (plan === '6months') return 'Prosegui con 6 mesi';
      if (plan === '1year') return 'Prosegui con 1 anno';
      if (plan === 'always') return 'Prosegui con Sempre attivo';
      return 'Scegli il piano';
    }

    function refreshSelectedPlanUI(){
      document.querySelectorAll('.card[data-plan]').forEach(card => {
        card.classList.toggle('selected', card.dataset.plan === selectedPlan);
      });
      document.getElementById('mainActionBtn').textContent = planButtonLabel(selectedPlan);
    }

    async function init(){
      const badge = document.getElementById('renewBadge');
      const sub = document.getElementById('renewSub');
      const plate = document.getElementById('vehiclePlate');
      const model = document.getElementById('vehicleModel');
      const feedbackBtn = document.getElementById('feedbackLinkBtn');

      feedbackBtn.href = feedbackUrl();

      document.querySelectorAll('.card[data-plan]').forEach(card => {
        card.addEventListener('click', () => {
          selectedPlan = card.dataset.plan || '6months';
          refreshSelectedPlanUI();
        });
      });

      document.getElementById('mainActionBtn').addEventListener('click', () => {
        const note = document.querySelector('.note');
        note.innerHTML = `<strong>Piano selezionato:</strong> ${planButtonLabel(selectedPlan).replace('Prosegui con ','')}. Il prossimo passaggio collegherà direttamente questo piano al pagamento online.`;
        note.scrollIntoView({ behavior:'smooth', block:'start' });
      });

      refreshSelectedPlanUI();

      if (!publicId) {
        setBadge(badge, 'Riferimento non valido', 'danger');
        sub.textContent = 'Impossibile identificare il servizio da rinnovare.';
        return;
      }

      try {
        const res = await fetch(`/api/public-renew/${encodeURIComponent(publicId)}`);
        const data = await res.json();

        if (!res.ok || !data.success || !data.data) {
          setBadge(badge, 'Riferimento non trovato', 'danger');
          sub.textContent = data.error || 'Impossibile caricare i dati del servizio.';
          return;
        }

        const d = data.data || {};
        const vehicleText = [d.brand, d.vehicle_model].filter(Boolean).join(' ').trim() || 'Veicolo registrato';
        plate.textContent = d.plate || '-';
        model.textContent = vehicleText;

        if (d.plan_type === 'always' || !d.expires_at) {
          setBadge(badge, 'Omaggio gratuito', 'ok');
          sub.textContent = `Il servizio per il veicolo ${d.plate || ''} risulta sempre attivo. Puoi comunque scegliere una formula diversa se desideri aggiornarlo o convertirlo.`;
        } else if (d.is_expired) {
          setBadge(badge, 'Servizio scaduto', 'danger');
          sub.innerHTML = `Il servizio per il veicolo <strong>${d.plate || ''}</strong> risulta scaduto. Ultima scadenza registrata: <strong>${fmtDateOnly(d.expires_at)}</strong>. Scegli ora come proseguire senza perdere continuità.`;
        } else if (String(d.plan_type || '').toLowerCase() === '1month') {
          setBadge(badge, 'Prova gratuita', 'warn');
          sub.innerHTML = `La prova attiva sul veicolo <strong>${d.plate || ''}</strong> risulta ancora valida. <strong>${d.days_left === 0 ? 'Scade oggi' : 'Scade tra ' + d.days_left + ' giorni'}</strong>. Puoi già scegliere adesso come proseguire senza interruzioni.`;
        } else {
          setBadge(badge, 'Servizio attivo', d.days_left !== null && d.days_left <= 15 ? 'warn' : 'ok');
          sub.innerHTML = `Il servizio del veicolo <strong>${d.plate || ''}</strong> è attivo. <strong>${d.days_left === 0 ? 'Scade oggi' : 'Scade tra ' + d.days_left + ' giorni'}</strong>. Qui puoi scegliere la formula più adatta per continuare.`;
        }
      } catch (e) {
        setBadge(badge, 'Errore di collegamento', 'danger');
        sub.textContent = 'Impossibile caricare i dati del rinnovo.';
      }
    }

    init();
  </script>
</body>
</html>
